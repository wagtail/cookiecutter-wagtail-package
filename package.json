{
  "name": "package-tooling",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "devDependencies": {
    "@wagtail/stylelint-config-wagtail": "^2.0.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.13.0"
  },
  "scripts": {
    "lint": "npm run lint:format && npm run lint:css",
    "lint:format": "prettier --check \"**/?(.)*.{css,scss,js,ts,tsx,json,yaml,yml}\"",
    "lint:css": "stylelint --allow-empty-input \"**/?(.)*.{css,scss}\"",
    "format": "prettier --write \"**/?(.)*.{css,scss,js,ts,tsx,json,yaml,yml}\""
  }
}
